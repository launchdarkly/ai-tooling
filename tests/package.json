{
  "name": "@launchdarkly/agent-skills-evals",
  "version": "1.0.0",
  "description": "LLM eval suite for LaunchDarkly agent skills and gram function tools",
  "private": true,
  "type": "module",
  "scripts": {
    "eval": "promptfoo eval --config evals/metrics/metric-create.eval.yaml --no-cache --output /tmp/promptfoo-results.json; node print-results.mjs",
