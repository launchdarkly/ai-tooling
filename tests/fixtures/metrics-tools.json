[
  {
    "type": "function",
    "function": {
      "name": "create-metric",
      "description": "Create a new metric in a LaunchDarkly project. Accepts measureType ('count', 'occurrence', 'value') and translates to API fields internally.",
      "parameters": {
        "type": "object",
        "properties": {
          "projectKey": { "type": "string", "description": "LaunchDarkly project key" },
          "key": { "type": "string", "description": "Unique metric key (immutable after creation)" },
          "name": { "type": "string", "description": "Display name" },
          "kind": { "type": "string", "enum": ["custom", "pageview", "click"] },
          "eventKey": { "type": "string", "description": "Event key for custom metrics" },
          "urls": {
            "type": "array",
            "description": "URL match rules for pageview/click metrics",
            "items": {
              "type": "object",
              "properties": {
                "kind": { "type": "string", "enum": ["substring", "exact", "canonical", "regex"] },
                "url": { "type": "string" }
              }
            }
          },
          "selector": { "type": "string", "description": "CSS selector for click metrics" },
          "measureType": { "type": "string", "enum": ["count", "occurrence", "value"] },
          "successCriteria": { "type": "string", "enum": ["HigherThanBaseline", "LowerThanBaseline"] },
          "valueAggregation": { "type": "string", "enum": ["average", "sum"], "description": "Only for measureType=value" },
          "unit": { "type": "string", "description": "Display unit label (e.g. 'ms', 'USD')" },
          "description": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["projectKey", "key", "name", "kind", "measureType", "successCriteria"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "get-metric",
      "description": "Get full details for a single LaunchDarkly metric.",
      "parameters": {
        "type": "object",
        "properties": {
          "projectKey": { "type": "string" },
          "metricKey": { "type": "string" }
        },
        "required": ["projectKey", "metricKey"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "list-metrics",
      "description": "List metrics in a LaunchDarkly project. Use to check for duplicates and learn naming conventions.",
      "parameters": {
        "type": "object",
        "properties": {
          "projectKey": { "type": "string" },
          "limit": { "type": "number" },
          "offset": { "type": "number" }
        },
        "required": ["projectKey"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "list-metric-events",
      "description": "List recent event keys received by a LaunchDarkly project. Use to check which events are flowing before creating a custom metric.",
      "parameters": {
        "type": "object",
        "properties": {
          "projectKey": { "type": "string" },
          "environmentKey": { "type": "string" }
        },
        "required": ["projectKey"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "get-environment",
      "description": "Get a LaunchDarkly environment and its SDK keys (server-side SDK key, client-side ID).",
      "parameters": {
        "type": "object",
        "properties": {
          "projectKey": { "type": "string" },
          "environmentKey": { "type": "string" }
        },
        "required": ["projectKey", "environmentKey"]
      }
    }
  }
]
