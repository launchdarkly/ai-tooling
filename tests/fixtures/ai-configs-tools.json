      "description": "Create a variation for an AI Config. Variations hold the model, parameters, and prompt (instructions for agent mode, messages array for completion mode). modelConfigKey must be {Provider}.{model-id} (e.g. OpenAI.gpt-4o).",
      "parameters": {
        "type": "object",
        "properties": {
          "projectKey": { "type": "string" },
          "configKey": { "type": "string" },
          "key": { "type": "string" },
          "name": { "type": "string" },
          "modelConfigKey": { "type": "string", "description": "e.g. OpenAI.gpt-4o or Anthropic.claude-3-5-sonnet" },
          "model": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "parameters": { "type": "object" }
            }
          },
          "instructions": { "type": "string", "description": "For agent mode: system instructions string" },
          "messages": {
            "type": "array",
            "description": "For completion mode: full messages array",
            "items": { "type": "object" }
          }
        },
        "required": ["projectKey", "configKey", "key", "name", "modelConfigKey"]
      }
    }
  },
